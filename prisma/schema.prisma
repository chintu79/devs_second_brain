// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  password      String?
  createdAt     DateTime  @default(now())
  resources     Resource[]
  prompts       Prompt[]
  notes         Note[]
  projects      Project[]
  tags          Tag[]
  references    Reference[]
  accounts      Account[]
  sessions      Session[]
  apiKeys       ApiKey[]
}

model Account {
  id                 String  @id @default(cuid())
  userId             String  @map("user_id")
  type               String
  provider           String
  providerAccountId  String  @map("provider_account_id")
  refresh_token      String? @db.Text
  access_token       String? @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String? @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Resource {
  id        String        @id @default(cuid())
  title     String
  url       String
  category  String
  notes     String?
  reason    String?
  favorite  Boolean       @default(false)
  createdAt DateTime      @default(now())
  user      User          @relation(fields: [userId], references: [id])
  userId    String
  tags      ResourceTag[]
}

model Prompt {
  id         String       @id @default(cuid())
  title      String
  prompt     String
  category   String
  useCase    String
  favorite   Boolean      @default(false)
  useCount   Int          @default(0)
  lastUsedAt DateTime?
  createdAt  DateTime     @default(now())
  user       User         @relation(fields: [userId], references: [id])
  userId     String
  tags       PromptTag[]
}

model Note {
  id        String    @id @default(cuid())
  title     String
  content   String
  category  String
  favorite  Boolean   @default(false)
  archived  Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  user      User      @relation(fields: [userId], references: [id])
  userId    String
  tags      NoteTag[]
}

model Project {
  id          String       @id @default(cuid())
  title       String
  description String
  status      String
  techStack   String[]
  planMd      String       @default("")
  favorite    Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  user        User         @relation(fields: [userId], references: [id])
  userId      String
  tags        ProjectTag[]
}

model Tag {
  id        String       @id @default(cuid())
  name      String
  userId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime     @default(now())
  resources ResourceTag[]
  prompts   PromptTag[]
  notes     NoteTag[]
  projects  ProjectTag[]

  @@unique([name, userId])
}

model ResourceTag {
  resourceId String
  tagId      String
  resource   Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  tag        Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([resourceId, tagId])
}

model PromptTag {
  promptId String
  tagId    String
  prompt   Prompt @relation(fields: [promptId], references: [id], onDelete: Cascade)
  tag      Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([promptId, tagId])
}

model NoteTag {
  noteId String
  tagId  String
  note   Note @relation(fields: [noteId], references: [id], onDelete: Cascade)
  tag    Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([noteId, tagId])
}

model ProjectTag {
  projectId String
  tagId     String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([projectId, tagId])
}

model Reference {
  id        String   @id @default(cuid())
  userId    String
  fromType  String   // "resource" | "note" | "prompt" | "project"
  fromId    String
  toType    String   // "resource" | "note" | "prompt" | "project"
  toId      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, fromType, fromId, toType, toId])
  @@index([fromType, fromId])
  @@index([toType, toId])
}

model ApiKey {
  id        String   @id @default(cuid())
  name      String
  key       String   @unique
  lastUsedAt DateTime?
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([key])
}
