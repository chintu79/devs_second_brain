{
  "name": "devventory",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "web:dev": "pnpm --filter @devventory/web dev",
    "web:build": "pnpm --filter @devventory/web build",
    "ext:dev": "pnpm --filter @devventory/extension dev",
    "ext:build": "pnpm --filter @devventory/extension build",
    "clean": "turbo clean && rm -rf node_modules"
  },
  "dependencies": {
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "turbo": "^2.5.0",
    "typescript": "^5"
  },
  "packageManager": "pnpm@11.9.0"
}
