DATABASE_URL="postgresql://postgres:mysecretpassword@localhost:5432/dev_second_brain"
NEXTAUTH_SECRET="replace-with-output-of-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Optional — GitHub token for Radar (higher API rate limits)
# Generate at https://github.com/settings/tokens (no scopes needed)
GITHUB_TOKEN=

# Optional — OpenRouter API key for AI chat features
# Get a free key at https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL="meta-llama/llama-3.2-3b-instruct:free"
