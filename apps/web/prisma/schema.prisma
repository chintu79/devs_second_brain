generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String?
  createdAt DateTime @default(now())

  items        KnowledgeItem[]
  captures     Capture[]
  collections  Collection[]
  tags         Tag[]
  apiKeys      ApiKey[]

  accounts     Account[]
  sessions     Session[]
}

model Account {
  id                String @id @default(cuid())
  userId            String @map("user_id")
  type              String
  provider          String
  providerAccountId String @map("provider_account_id")
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model KnowledgeItem {
  id           String    @id @default(cuid())
  userId       String
  type         String    @default("link")
  title        String
  content      String?
  url          String?
  domain       String?
  provider     String?
  summary      String?
  notes        String?
  metadata     Json?
  status       String    @default("active")
  favorite     Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  lastOpenedAt DateTime?
  archivedAt  DateTime?
  deletedAt   DateTime?

  captureId String?    @unique
  capture   Capture?   @relation(fields: [captureId], references: [id])

  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  collections KnowledgeCollection[]
  tags        KnowledgeTag[]
  attachments Attachment[]

  backlinksFrom Backlink[]     @relation("BacklinkFrom")
  backlinksTo   Backlink[]     @relation("BacklinkTo")

  @@index([userId, status])
  @@index([userId, type])
  @@index([userId, domain])
  @@index([title])
}

model Capture {
  id           String        @id @default(cuid())
  userId       String
  source       String        // "extension" | "web" | "api" | "import"
  type         String        // "reference" | "note" | "document"
  status       String        @default("pending") // pending | processing | ready | failed

  payload     Json
  steps       Json?          // StepRecord[]
  error       String?
  retries     Int            @default(0)

  knowledgeItemId String?    @unique
  knowledgeItem   KnowledgeItem?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([createdAt])
  @@index([knowledgeItemId])
}

model Collection {
  id        String   @id @default(cuid())
  name      String
  parentId  String?
  sortOrder Int      @default(0)
  userId    String
  createdAt DateTime @default(now())

  user     User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent   Collection?         @relation("CollectionHierarchy", fields: [parentId], references: [id])
  children Collection[]        @relation("CollectionHierarchy")
  items    KnowledgeCollection[]

  @@index([userId, parentId])
}

model KnowledgeCollection {
  itemId       String
  collectionId String
  item         KnowledgeItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  collection   Collection    @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  @@id([itemId, collectionId])
}

model Tag {
  id        String   @id @default(cuid())
  name      String
  userId    String
  createdAt DateTime @default(now())

  user  User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  items KnowledgeTag[]

  @@unique([name, userId])
}

model KnowledgeTag {
  itemId String
  tagId  String
  item   KnowledgeItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  tag    Tag           @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([itemId, tagId])
}

model Attachment {
  id        String   @id @default(cuid())
  itemId    String
  type      String
  url       String
  mimeType  String?
  size      Int?
  name      String?
  metadata  Json?
  createdAt DateTime @default(now())

  item KnowledgeItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemId])
}

model Backlink {
  id     String @id @default(cuid())
  fromId String
  toId   String

  from KnowledgeItem @relation("BacklinkFrom", fields: [fromId], references: [id], onDelete: Cascade)
  to   KnowledgeItem @relation("BacklinkTo", fields: [toId], references: [id], onDelete: Cascade)

  @@unique([fromId, toId])
  @@index([fromId])
  @@index([toId])
}

model ApiKey {
  id         String    @id @default(cuid())
  name       String
  key        String    @unique
  keyPrefix  String?   // first 16 chars of SHA-256(rawKey) — null for legacy keys
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([keyPrefix])
}

