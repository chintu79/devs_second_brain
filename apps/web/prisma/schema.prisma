generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id         String      @id @default(cuid())
  email      String      @unique
  name       String?
  password   String?
  createdAt  DateTime    @default(now())
  apiKeys         ApiKey[]
  radarBookmarks  RadarBookmark[]
  notes      Note[]
  projects   Project[]
  prompts    Prompt[]
  references Reference[]
  resources  Resource[]
  dailyEntries DailyEntry[]
  tags       Tag[]
  accounts   Account[]
  sessions   Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Resource {
  id        String        @id @default(cuid())
  title     String
  url       String
  category  String
  notes     String?
  createdAt DateTime      @default(now())
  userId    String
  favorite  Boolean       @default(false)
  reason    String?
  user      User          @relation(fields: [userId], references: [id])
  tags      ResourceTag[]
}

model Prompt {
  id         String      @id @default(cuid())
  title      String
  prompt     String
  category   String
  useCase    String
  favorite   Boolean     @default(false)
  createdAt  DateTime    @default(now())
  userId     String
  lastUsedAt DateTime?
  useCount   Int         @default(0)
  user       User        @relation(fields: [userId], references: [id])
  tags       PromptTag[]
}

model Note {
  id        String    @id @default(cuid())
  title     String
  content   String
  category  String
  createdAt DateTime  @default(now())
  userId    String
  archived  Boolean   @default(false)
  favorite  Boolean   @default(false)
  updatedAt DateTime  @updatedAt
  user      User      @relation(fields: [userId], references: [id])
  tags      NoteTag[]
}

model Project {
  id          String       @id @default(cuid())
  title       String
  description String
  status      String
  techStack   String[]
  createdAt   DateTime     @default(now())
  userId      String
  favorite    Boolean      @default(false)
  planMd      String       @default("")
  updatedAt   DateTime     @updatedAt
  user        User         @relation(fields: [userId], references: [id])
  tags        ProjectTag[]
}

model Tag {
  id        String        @id @default(cuid())
  name      String
  userId    String
  createdAt DateTime      @default(now())
  notes     NoteTag[]
  projects  ProjectTag[]
  prompts   PromptTag[]
  resources ResourceTag[]
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([name, userId])
}

model ResourceTag {
  resourceId String
  tagId      String
  resource   Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  tag        Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([resourceId, tagId])
}

model PromptTag {
  promptId String
  tagId    String
  prompt   Prompt @relation(fields: [promptId], references: [id], onDelete: Cascade)
  tag      Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([promptId, tagId])
}

model NoteTag {
  noteId String
  tagId  String
  note   Note   @relation(fields: [noteId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([noteId, tagId])
}

model ProjectTag {
  projectId String
  tagId     String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([projectId, tagId])
}

model Reference {
  id        String   @id @default(cuid())
  userId    String
  fromType  String
  fromId    String
  toType    String
  toId      String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, fromType, fromId, toType, toId])
  @@index([fromType, fromId])
  @@index([toType, toId])
}

model AppConfig {
  key       String   @id
  value     String
  updatedAt DateTime @default(now()) @updatedAt
}

model ApiKey {
  id         String    @id @default(cuid())
  name       String
  key        String    @unique
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([key])
}

model DailyEntry {
  id        String   @id @default(cuid())
  date      DateTime @map("date")
  content   String
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, date])
  @@map("daily_entries")
}

model RadarBookmark {
  id        String   @id @default(cuid())
  repoId    String
  userId    String
  repoData  String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([repoId, userId])
  @@index([userId])
}
