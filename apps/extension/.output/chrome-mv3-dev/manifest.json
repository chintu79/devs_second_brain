{
  "manifest_version": 3,
  "name": "Devventory",
  "description": "The fastest way to capture knowledge from any page",
  "version": "0.1.0",
  "permissions": [
    "storage",
    "activeTab",
    "contextMenus",
    "scripting",
    "tabs"
  ],
  "action": {},
  "commands": {
    "wxt:reload-extension": {
      "description": "Reload the extension during development",
      "suggested_key": {
        "default": "Alt+R"
      }
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "host_permissions": [
    "*://github.com/*",
    "*://www.youtube.com/*",
    "*://youtu.be/*",
    "*://developer.mozilla.org/*",
    "*://react.dev/*",
    "*://nextjs.org/*",
    "*://tailwindcss.com/*",
    "*://svelte.dev/*",
    "http://localhost/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval' http://localhost:3001; object-src 'self';",
    "sandbox": "script-src 'self' 'unsafe-inline' 'unsafe-eval' http://localhost:3001; sandbox allow-scripts allow-forms allow-popups allow-modals; child-src 'self';"
  }
}